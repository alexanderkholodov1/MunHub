# MunHub Lab v6.0 — fleet environment template (COMMITTED — no real values here).
#
# The REAL secrets live ONLY in `private/.env.fleet` (gitignored) or are sourced at runtime from
# the key files already in `private/` via `infra/fleet/load-fleet-env.sh`.
# NEVER put real keys in this file. NEVER commit real keys.

# Gemini CLI / API
GEMINI_API_KEY=

# Cursor API (background agents / CLI)
CURSOR_API_KEY=

# GitHub — fine-grained PAT for the fleet: contents:write + pull-requests:write, NO admin/bypass.
# (Distinct from Alexander's gh OAuth token, which is for setup/admin only.)
GITHUB_PAT=
