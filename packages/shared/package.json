{
  "name": "@munhub/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types, Zod schemas, constants, i18n keys, and pure utilities",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
